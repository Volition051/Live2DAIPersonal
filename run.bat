@echo off
chcp 65001 >nul
echo ==========================================
echo   Starting FastAPI Server...
echo ==========================================

@echo off
:: 设置标题,方便识别
title 项目控制台 - 正在启动前后端服务...

echo ==========================================
echo   正在准备启动前后端服务...
echo   请勿关闭此窗口,直接点击最小化即可
echo ==========================================

:: 获取当前脚本所在目录
set "PROJECT_ROOT=%~dp0"

:: ----------------------------------------------------
::  1. 前端服务 (Frontend)
:: ----------------------------------------------------
start "前端服务 (Frontend)" cmd /k "cd /d "%PROJECT_ROOT%frontend-tourist" && npm run dev"

:: ----------------------------------------------------
::  2. 后端服务 (Backend)
:: ----------------------------------------------------
start "后端服务 (Backend)" cmd /k "cd /d "%PROJECT_ROOT%" && call .venv\Scripts\activate.bat && cd backend && python -m uvicorn app.main:app --reload --host 0.0.0.0 --port 8000"

:: ----------------------------------------------------
:: 等待用户确认显示
:: ----------------------------------------------------
echo.
echo [成功] 两个终端窗口已经分别打开
echo - 前端窗口正在启动...
echo - 后端窗口正在启动...
echo.
echo 请查看新开的窗口信息,不要关闭当前的这个窗口
pause
