{
  "name": "frontend-tourist",
  "private": true,
  "version": "0.0.0",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite --host\" \"wait-on http://localhost:3001 && electron .\"",
    "electron:build": "vite build && electron-builder",
    "electron:build:win": "vite build && electron-builder --win"
  },
  "dependencies": {
    "axios": "^1.16.0",
    "leaflet": "^1.9.4",
    "pinia": "^3.0.4",
    "pixi-live2d-display": "^0.4.0",
    "pixi.js": "^6.5.10",
    "playwright": "^1.60.0",
    "vant": "^4.9.24",
    "vue": "^3.5.32",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "@vant/auto-import-resolver": "^1.3.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "concurrently": "^10.0.3",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.2",
    "postcss-px-to-viewport": "^1.1.1",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^8.0.10",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.scenicspot.terminal",
    "productName": "景区智能导览终端",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/app-icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "景区智能导览"
    }
  }
}
